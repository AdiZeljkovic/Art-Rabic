# ============================================================================
# mikulicknjige.com - environment varijable
# Kopiraj u .env na serveru:  cp .env.example .env && nano .env
# .env je u .gitignore i NIKAD se ne commituje.
# Prava na serveru:  chmod 600 .env
# ============================================================================

# --- OBAVEZNO ---------------------------------------------------------------

# DATABASE_URL: konekcija na MariaDB. Koristi ga Prisma adapter (lib/prisma.ts)
# i Prisma CLI (prisma.config.ts) za migrate/seed.
# Format: mysql://korisnik:lozinka@host:port/baza
# Lozinku URL-encode-uj ako sadrzi @ : / ? # [ ] znakove.
DATABASE_URL="mysql://adizeljkovic_mikulic:LOZINKA@127.0.0.1:3306/adizeljkovic_mikulic"

# COOKIE_SECRET: HMAC-SHA256 kljuc za potpisivanje admin session cookieja
# (lib/auth.ts). NEMA fallback u kodu - ako fali, svaki login baca 500.
# Generisi:  openssl rand -hex 32
# Promjena ove vrijednosti odjavljuje sve admine.
COOKIE_SECRET="generisi_sa_openssl_rand_hex_32"

# NODE_ENV: mora biti "production" na serveru.
# Kontrolise `secure` flag na admin cookieju (lib/auth.ts:68) - bez ovoga
# se session cookie salje i preko HTTP-a. PM2 ga postavlja preko ecosystem.config.js.
NODE_ENV="production"

# PORT: nginx reverse proxy gadja 127.0.0.1:3006
PORT=3006

# HOSTNAME: vezi se samo na loopback da app nije dostupna direktno izvana.
HOSTNAME="127.0.0.1"


# --- SMTP (trenutno nekonfigurisano - narudzbe i kontakt forma ne salju mail) -

# SMTP_HOST: fallback u kodu je "localhost" (lib/email.ts:4).
# Ako lokalni MTA ne postoji, sendMail baca gresku.
SMTP_HOST="mail.mikulicknjige.com"

# SMTP_PORT: fallback "587". Za 465 postavi i secure:true u lib/email.ts.
SMTP_PORT=587

# SMTP_USER: ako je prazan, nodemailer ide bez autentikacije (lib/email.ts:7).
SMTP_USER="info@mikulicknjige.com"

# SMTP_PASS: lozinka mailboxa iz HestiaCP Mail sekcije.
SMTP_PASS=""

# SMTP_FROM: adresa u From headeru. Fallback lanac: SMTP_FROM -> SMTP_USER
# -> "info@artrabic.ba" (lib/email.ts:13) - taj zadnji fallback je pogresan
# domen i zavrsit ce u spamu, pa ovo postavi eksplicitno.
SMTP_FROM="info@mikulicknjige.com"

# ADMIN_EMAIL: gdje stizu obavijesti o novim narudzbama i porukama.
# Isti fallback lanac kao gore (lib/email.ts:14).
ADMIN_EMAIL="info@mikulicknjige.com"


# --- SAMO ZA SEED (ne treba na serveru u runtimeu) ---------------------------

# ADMIN_PASSWORD: koristi ga prisma/seed.ts pri kreiranju admin naloga.
# Minimum 16 znakova — seed odbija raditi sa slabijom lozinkom.
# Postavi prije `npx prisma db seed`, pa obrisi iz .env.
# ADMIN_PASSWORD=""

# ADMIN_USERNAME: korisnicko ime admina. Default je "admin".
# ADMIN_USERNAME="artrabica"
